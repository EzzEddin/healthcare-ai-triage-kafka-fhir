# =============================================================================
# Steer Health POC - Environment Variables
# =============================================================================
# Copy this to .env and fill in your API keys

# AI Provider (choose one or both)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Voice AI (optional - for voice demo)
DEEPGRAM_API_KEY=your-deepgram-key-here
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# Twilio (optional - for SMS/voice call demo)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Infrastructure (defaults for docker-compose)
KAFKA_BROKER=localhost:9092
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=steer_health
POSTGRES_USER=steer
POSTGRES_PASSWORD=steer_dev_2024
REDIS_HOST=localhost
REDIS_PORT=6379

# API Gateway
API_PORT=3001
WS_PORT=3002
